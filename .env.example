# Copia este archivo como .env.local y completa con tus datos reales.
# La cadena la obtienes en MongoDB Atlas: Cluster -> Connect -> Drivers.
MONGODB_URI="mongodb+srv://USUARIO:CONTRASENA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="cesde_consultor"

# Clave de Groq para la sintesis con IA (https://console.groq.com/keys)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxx"
# Modelo opcional (por defecto llama-3.3-70b-versatile)
GROQ_MODEL="llama-3.3-70b-versatile"
